<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login & Signup Form</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-database-compat.js"></script>
</head>
<body>
    <div class="auth-wrapper">
        <div class="background-shape"></div>
        <div class="secondary-shape"></div>
        
        <!-- Login Panel -->
        <div class="credentials-panel signin">
            <h2 class="slide-element">Login</h2>
            <form id="loginForm">
                <div class="field-wrapper slide-element">
                    <input type="text" id="loginEmail" required>
                    <label for="">Username/Email</label>
                    <i class="fa-solid fa-user"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <input type="password" id="loginPassword" required>
                    <label for="">Password</label>
                    <i class="fa-solid fa-lock"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <button class="submit-button" type="submit">Login</button>
                </div>

                <div class="switch-link slide-element">
                    <p><a href="#" id="forgotPassword">Forgot Password?</a></p>
                    <p>Don't have an account? <br> <a href="#" class="register-trigger">Sign Up</a></p>
                </div>
            </form>
        </div>

        <!-- Register Panel -->
        <div class="credentials-panel signup">
            <h2 class="slide-element">Register</h2>
            <form id="registerForm">
                <div class="field-wrapper slide-element">
                    <input type="text" id="regName" required>
                    <label for="">Full Name</label>
                    <i class="fa-solid fa-user"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <input type="email" id="regEmail" required>
                    <label for="">Email</label>
                    <i class="fa-solid fa-envelope"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <select id="regBranch" required style="background: transparent; color: white; border: none; border-bottom: 2px solid #fff; width: 100%; height: 100%;">
                        <option value="" disabled selected style="color: #666;">Select Branch</option>
                        <option value="Computer Science" style="color: #000;">Computer Science</option>
                        <option value="Electrical Engineering" style="color: #000;">Electrical Engineering</option>
                        <option value="Mechanical Engineering" style="color: #000;">Mechanical Engineering</option>
                        <option value="Civil Engineering" style="color: #000;">Civil Engineering</option>
                        <option value="Electronics Engineering" style="color: #000;">Electronics Engineering</option>
                    </select>
                    <label style="top: -20px; color: #00d4ff;">Branch</label>
                    <i class="fa-solid fa-building"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <input type="text" id="regRollNo" required>
                    <label for="">Roll Number</label>
                    <i class="fa-solid fa-id-card"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <input type="password" id="regPassword" required>
                    <label for="">Password</label>
                    <i class="fa-solid fa-lock"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <button class="submit-button" type="submit">Register</button>
                </div>

                <div class="switch-link slide-element">
                    <p>Already have an account? <br> <a href="#" class="login-trigger">Sign In</a></p>
                </div>
            </form>
        </div>

        <!-- Welcome Sections -->
        <div class="welcome-section signin">
            <h2 class="slide-element">WELCOME BACK!</h2>
        </div>

        <div class="welcome-section signup">
            <h2 class="slide-element">WELCOME!</h2>
        </div>
    </div>

    <!-- Forgot Password Modal -->
    <div id="forgotModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; justify-content: center; align-items: center;">
        <div style="background: #1a1a2e; padding: 30px; border-radius: 10px; border: 2px solid #00d4ff; max-width: 400px; width: 90%;">
            <h3 style="color: #fff; margin-bottom: 20px;">Reset Password</h3>
            <div class="field-wrapper" style="margin-bottom: 20px;">
                <input type="email" id="resetEmail" required style="width: 100%; padding: 10px; background: transparent; border: none; border-bottom: 2px solid #fff; color: #fff;">
                <label style="color: #fff;">Enter your email</label>
            </div>
            <div class="field-wrapper" style="margin-bottom: 20px;">
                <input type="password" id="newPassword" required style="width: 100%; padding: 10px; background: transparent; border: none; border-bottom: 2px solid #fff; color: #fff;">
                <label style="color: #fff;">New Password</label>
            </div>
            <button onclick="resetPassword()" style="width: 100%; padding: 10px; background: transparent; border: 2px solid #00d4ff; color: #fff; cursor: pointer; margin-bottom: 10px;">Reset Password</button>
            <button onclick="closeModal()" style="width: 100%; padding: 10px; background: transparent; border: 2px solid #ff4444; color: #fff; cursor: pointer;">Close</button>
        </div>
    </div>

    <div class="footer">
        <p>Made with ❤️ by <a href="#" target="_blank">suraj.AI</a></p>
    </div>

    <script>
        // Firebase Configuration - Your exact config
        const firebaseConfig = {
            apiKey: "AIzaSyDkbbYdIMlEgCQlR0Pf1dBA1F_KVOFWZcA",
            authDomain: "schoolsurajai.firebaseapp.com",
            databaseURL: "https://schoolsurajai-default-rtdb.firebaseio.com",
            projectId: "schoolsurajai",
            storageBucket: "schoolsurajai.firebasestorage.app",
            messagingSenderId: "413213207096",
            appId: "1:413213207096:web:5c0c2742e3150c8bd154cd"
        };

        // Initialize Firebase
        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();

        // Admin credentials
        const ADMIN_EMAIL = "suraj14112009@gmail.com";
        const ADMIN_PASSWORD = "84068";

        // Your exact toggle code
        const authWrapper = document.querySelector('.auth-wrapper');
        const loginTrigger = document.querySelector('.login-trigger');
        const registerTrigger = document.querySelector('.register-trigger');

        registerTrigger.addEventListener('click', (e) => {
            e.preventDefault();
            authWrapper.classList.add('toggled');
        });

        loginTrigger.addEventListener('click', (e) => {
            e.preventDefault();
            authWrapper.classList.remove('toggled');
        });

        // Forgot password modal
        document.getElementById('forgotPassword').addEventListener('click', (e) => {
            e.preventDefault();
            document.getElementById('forgotModal').style.display = 'flex';
        });

        function closeModal() {
            document.getElementById('forgotModal').style.display = 'none';
        }

        // Reset password function
        function resetPassword() {
            const email = document.getElementById('resetEmail').value;
            const newPassword = document.getElementById('newPassword').value;
            
            if (!email || !newPassword) {
                alert('Please fill all fields');
                return;
            }

            database.ref('students').orderByChild('email').equalTo(email).once('value', snapshot => {
                if (snapshot.exists()) {
                    const userId = Object.keys(snapshot.val())[0];
                    database.ref(`students/${userId}/password`).set(newPassword);
                    alert('Password reset successfully! Please login with new password.');
                    closeModal();
                } else {
                    alert('Email not found!');
                }
            });
        }

        // Login form submission
        document.getElementById('loginForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;

            // Check for admin
            if (email === ADMIN_EMAIL && password === ADMIN_PASSWORD) {
                localStorage.setItem('userType', 'admin');
                window.location.href = 'dashboard.html';
                return;
            }

            // Check student login
            database.ref('students').orderByChild('email').equalTo(email).once('value', snapshot => {
                if (snapshot.exists()) {
                    const studentData = Object.values(snapshot.val())[0];
                    if (studentData.password === password) {
                        localStorage.setItem('userType', 'student');
                        localStorage.setItem('currentStudent', JSON.stringify(studentData));
                        window.location.href = 'dashboard.html';
                    } else {
                        alert('Invalid password!');
                    }
                } else {
                    alert('Email not found!');
                }
            });
        });

        // Register form submission
        document.getElementById('registerForm').addEventListener('submit', (e) => {
            e.preventDefault();
            
            const studentData = {
                name: document.getElementById('regName').value,
                email: document.getElementById('regEmail').value,
                branch: document.getElementById('regBranch').value,
                rollNo: document.getElementById('regRollNo').value,
                password: document.getElementById('regPassword').value,
                createdAt: new Date().toISOString()
            };

            database.ref('students').orderByChild('email').equalTo(studentData.email).once('value', snapshot => {
                if (snapshot.exists()) {
                    alert('Email already registered!');
                } else {
                    const newStudentRef = database.ref('students').push();
                    newStudentRef.set(studentData)
                        .then(() => {
                            alert('Registration successful! Please login.');
                            authWrapper.classList.remove('toggled');
                            document.getElementById('registerForm').reset();
                        })
                        .catch(error => {
                            alert('Error: ' + error.message);
                        });
                }
            });
        });
    </script>
</body>
</html>
